{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": ".artifacts/ai/ainpc-repo.xml",
    "style": "xml",
    "compress": false,
    "parsableStyle": true,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "instructionFilePath": "AGENTS.md"
  },
  "include": [
    "AGENTS.md",
    "DEVELOPMENT.md",
    "docs/**/*.md",
    "Config/**/*",
    "Source/**/*",
    "Plugins/AINpc/**/*",
    "scripts/dev/**/*"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/Binaries/**",
      "**/Intermediate/**",
      "**/Saved/**",
      "**/Temp/**",
      "**/DerivedDataCache/**",
      "**/*.log",
      "**/*.pid",
      "**/*.bak",
      ".continue/**",
      ".claude/**",
      ".codex/**",
      ".agents/**",
      "openspec/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
