[
  {
    "schemaVersion": 2,
    "testId": "us1.dialogue-action",
    "map": "/Game/Maps/AINpcTestMap",
    "timeoutSec": 180,
    "storyIds": ["US-1"],
    "phaseIds": ["phase2.7"],
    "fixture": {
      "adapterId": "builtin.characterFixture",
      "kind": "characterWithSmartObject"
    },
    "persona": {
      "file": "AINpcVisualHarnessUs1Persona.txt",
      "delayFillerFile": "AINpcVisualHarnessDelayFiller.txt",
      "delayFillerThreshold": 0.0
    },
    "prompt": {
      "file": "AINpcVisualHarnessInitialPrompt.txt",
      "variables": {
        "SmartObjectTargetId": "runtime.smartObjectTargetId"
      }
    },
    "steps": [
      {
        "type": "dialogue.start",
        "payload": {
          "promptRef": "prompt"
        }
      },
      {
        "type": "wait.until",
        "payload": {
          "timeoutSec": 90
        },
        "condition": {
          "all": [
            { "equals": { "observation": "sessionStarted", "value": true } },
            { "equals": { "observation": "waitingStateObserved", "value": true } },
            { "equals": { "observation": "speakingStateObserved", "value": true } },
            { "equals": { "observation": "dialogueResponseObserved", "value": true } },
            { "equals": { "observation": "delayMaskingEndObserved", "value": true } },
            { "equals": { "observation": "actionIntentObserved", "value": true } }
          ]
        }
      },
      {
        "type": "action.executeLatestIntent",
        "payload": {
          "adapterId": "builtin.smartObjectAction",
          "actorRef": "fixture.npc",
          "allowActionRejection": false
        }
      },
      {
        "type": "observe.hold",
        "payload": {
          "observation": "actionTargetReached",
          "durationSec": 3.0
        }
      }
    ],
    "expect": {
      "all": [
        { "equals": { "observation": "sessionStarted", "value": true } },
        { "equals": { "observation": "dialogueResponseObserved", "value": true } },
        { "equals": { "observation": "actionExecutionAccepted", "value": true } },
        { "equals": { "observation": "actionTargetReached", "value": true } },
        { "equals": { "observation": "actionTargetReachedHoldElapsed", "value": true } }
      ]
    }
  },
  {
    "schemaVersion": 2,
    "testId": "us2.perception-behavior",
    "map": "/Game/Maps/AINpcTestMap",
    "timeoutSec": 240,
    "storyIds": ["US-2"],
    "phaseIds": ["phase2.7"],
    "fixture": {
      "adapterId": "builtin.characterFixture",
      "kind": "characterWithSmartObject"
    },
    "persona": {
      "file": "AINpcVisualHarnessUs2Persona.txt",
      "delayFillerFile": "AINpcVisualHarnessDelayFiller.txt",
      "delayFillerThreshold": 30.0
    },
    "prompt": {
      "file": "AINpcVisualHarnessUs2Prompt.txt",
      "variables": {
        "SmartObjectTargetId": "runtime.smartObjectTargetId",
        "EventTriggerId": "US2_EVENT_TRIGGER_GIFT_001"
      }
    },
    "steps": [
      {
        "type": "dialogue.start",
        "payload": {
          "promptRef": "prompt"
        }
      },
      {
        "type": "world.event",
        "payload": {
          "adapterId": "builtin.npcEvent",
          "eventTag": "AINpc.Tests.Route.Match",
          "targetRef": "fixture.npc"
        }
      },
      {
        "type": "wait.until",
        "payload": {
          "timeoutSec": 120
        },
        "condition": {
          "all": [
            { "equals": { "observation": "sessionStarted", "value": true } },
            { "equals": { "observation": "waitingStateObserved", "value": true } },
            { "equals": { "observation": "speakingStateObserved", "value": true } },
            { "equals": { "observation": "eventTriggerBroadcast", "value": true } },
            { "equals": { "observation": "partialResponseObserved", "value": true } },
            { "equals": { "observation": "structuredResponseObserved", "value": true } },
            { "equals": { "observation": "actionIntentObserved", "value": true } },
            { "equals": { "observation": "delayMaskingEndObserved", "value": true } }
          ]
        }
      },
      {
        "type": "action.executeLatestIntent",
        "payload": {
          "adapterId": "builtin.smartObjectAction",
          "actorRef": "fixture.npc",
          "allowActionRejection": true
        }
      }
    ],
    "expect": {
      "all": [
        { "equals": { "observation": "sessionStarted", "value": true } },
        { "equals": { "observation": "eventTriggerBroadcast", "value": true } },
        { "equals": { "observation": "structuredResponseObserved", "value": true } },
        {
          "anyOf": [
            { "equals": { "observation": "actionExecutionAccepted", "value": true } },
            { "equals": { "observation": "actionRejectedVisible", "value": true } }
          ]
        }
      ]
    }
  },
  {
    "schemaVersion": 2,
    "testId": "phase27.prompt-only-dialogue-action",
